{
  "_companion_url_note": "DEPRECATED — prefer agent/config/companion.json (companion.advertise_host + companion.port). companion_url is still honored here during the migration window; when companion.json is present it wins.",
  "default_tier": 1,
  "project_tier": 1,
  "auto_save": false,
  "fm_app_name": "FileMaker Pro",
  "companion_url": "http://localhost:8765",

  "_wsl2_note": "The two keys below are only needed on Windows + WSL2. The companion server auto-detects the export path via cmd.exe+wslpath; set export_dir_override only if auto-detection fails.",
  "repo_path_override": "/home/<you>/agentic-fm",
  "export_dir_override": "/mnt/c/Users/<you>/Desktop",

  "tiers": {
    "0": {
      "description": "Plug-in direct — agent selects a script-write endpoint from the AgenticFM plug-in's /api/discover suite (zero keystrokes); requires the plug-in to be usable",
      "requires": ["plugin"]
    },
    "1": {
      "description": "Clipboard only — agent writes XML to clipboard, developer pastes with Cmd+V",
      "requires": []
    },
    "2": {
      "description": "MBS auto-paste — agent writes clipboard, MBS navigates Script Workspace and pastes",
      "requires": ["mbs_plugin"]
    },
    "3": {
      "description": "Full autonomy — AppleScript creates script placeholders, MBS auto-pastes",
      "requires": ["mbs_plugin", "accessibility_permission"]
    }
  }
}

<?xml version="1.0"?>
<fmxmlsnippet type="FMObjectList">
  <Step enable="True" id="161" name="Insert from Device">
    <InsertFrom value="Camera"/>
    <DeviceOptions>
      <Camera choice="Back"/>
      <Resolution choice="Full"/>
      <LightMode choice="Auto"/>
    </DeviceOptions>
  </Step>
</fmxmlsnippet>
<!-- Re-captured 2026-06-27 on FM Pro 26.0.1 (adds LightMode; current FM omits the <Field> when no target is set). -->
<!-- InsertFrom value: "Camera" | "Video Camera" | "Microphone" | "Photo Library" | "Music Library" | "Barcode" | "Signature" -->
<!-- Field (optional, before DeviceOptions): target container field <Field table id name/>, or <Field>$variable</Field>. Omitted ⇒ active container field. -->
<!-- DeviceOptions children vary by InsertFrom type (present-driven; each round-trips by presence): -->
<!-- Camera: Camera, Resolution, LightMode -->
<!-- Camera choice: "Back" | "Front". Resolution choice: "Full" | "Large" | "Medium" | "Small". LightMode choice: "Auto" | "On" | "Off". -->
<!-- Music Library / Photo Library: (no DeviceOptions) -->
<!-- Video Camera: Camera, Resolution, LightMode, MaxDuration, StartImmediately -->
<!-- Microphone: MaxDuration, StartImmediately -->
<!-- MaxDuration state: "True" with a direct <Calculation> child (seconds) | "False". StartImmediately state: "True" | "False". -->
<!-- Barcode: ScanFrom, then (ScanFrom type="Camera" ⇒ Camera/Resolution/LightMode) or (ScanFrom type="Field" ⇒ a <Field> source ref), then Barcodes. -->
<!-- ScanFrom type: "Camera" | "Field". Barcodes types: numeric bitmask. "4194303" (0x3FFFFF) = all 22 types enabled. -->
<!-- Barcode types (bit positions): Code 39, Code 93, Code 128, EAN-8, EAN-13, EAN/UPC Composite, GS1 2-Digit Add-On, GS1 5-Digit Add-On, GS1 DataBar Expanded, GS1 DataBar (RSS), Interleaved 2 of 5, ISBN-10 (from EAN-13), ISBN-13 (from EAN-13), QR Code, UPC-A, UPC-E, Codabar, PDF417, ITF-14, Aztec, Data Matrix, GS1 DataBar Limited. -->
<!-- Signature: Title (Calculation), Message (Calculation), Prompt (Calculation), Presentation. -->
<!-- Presentation choice: "Full Screen" | "Overlay" | "Embedded". Falls back to Overlay if container too small. -->
<!-- FileMaker Go only; not supported on Pro, WebDirect, Server, Cloud, Data API, or CWP. -->
<!-- See https://help.claris.com/en/pro-help/content/insert-from-device.html -->

<fmxmlsnippet type="FMObjectList">
  <Step enable="True" id="247" name="Cancel PDF"/>
</fmxmlsnippet>
<!-- No parameters. Closes the currently open PDF file in memory without saving it. -->
<!-- Use to discard an in-progress PDF (e.g. on error during generation, or when a user cancels). Contrast with Close PDF, which saves. -->
<!-- New in FileMaker 26.0. Authoritative capture: <Step id="247" name="Cancel PDF"> with no parameter elements (FM emits only the cosmetic DisableStepCollapsed, omitted here). -->
<!-- See https://help.claris.com/en/pro-help/content/cancel-pdf.html -->

<?xml version="1.0"?>
<fmxmlsnippet type="FMObjectList">
  <Step enable="True" id="144" name="Save Records as PDF">
    <NoInteract state="True"/>
    <Option state="False"/>
    <CreateDirectories state="True"/>
    <Restore state="True"/>
    <AutoOpen state="False"/>
    <CreateEmail state="False"/>
    <UniversalPathList>$path</UniversalPathList>
    <Calculation><![CDATA["title"]]></Calculation>
    <PDFOptions source="RecordsBeingBrowsed">
      <Document>
        <Title>
          <Calculation><![CDATA["title"]]></Calculation>
        </Title>
        <Subject>
          <Calculation><![CDATA["subject"]]></Calculation>
        </Subject>
        <Author>
          <Calculation><![CDATA["author"]]></Calculation>
        </Author>
        <Keywords>
          <Calculation><![CDATA["keywords"]]></Calculation>
        </Keywords>
        <Pages AllPages="True">
          <NumberFrom>
            <Calculation><![CDATA[1]]></Calculation>
          </NumberFrom>
        </Pages>
      </Document>
      <Security allowScreenReader="True" enableCopying="True" controlEditing="AnyExceptExtractingPages" controlPrinting="HighResolution" requireControlEditPassword="False" requireOpenPassword="False"/>
      <View magnification="100" pageLayout="SinglePage" show="PagesPanelAndPage"/>
    </PDFOptions>
  </Step>
</fmxmlsnippet>
<!-- NoInteract state: "True" suppresses dialog boxes (if file already specified). "False" displays dialog boxes when script step is performed. -->
<!-- Option state: "True" appends to existing PDF (Append). "False" creates new PDF or overwrites existing. When appending: Document and Initial View tab settings ignored; Security tab settings not applied; if PDF is password-protected, password must match. -->
<!-- CreateDirectories state: "True" creates new folders specified in output file path. "False" does not create folders. -->
<!-- Restore state: "True" uses stored/specified options. "False" does not restore stored options. -->
<!-- AutoOpen state: "True" automatically opens output file with default application. "False" does not open file. -->
<!-- CreateEmail state: "True" displays new email message in user's default email application with output file attached. "False" does not create email. -->
<!-- Calculation (sibling before PDFOptions): label/title for the stored PDF specification shown in the UI. Only present when Restore state="True". -->
<!-- PDFOptions source attribute: "RecordsBeingBrowsed" | "CurrentRecord" | "BlankRecord" -->
<!-- PDFOptions appearance attribute (BlankRecord only): "AsFormatted" | "WithBoxes" | "WithUnderlines" | "WithPlaceholderText" -->
<!-- Pages AllPages attribute: "True" saves all pages. "False" saves specified page range (uses NumberFrom and optionally PageRange/From/To). -->
<!-- Security attributes:
  allowScreenReader: "True" | "False"
  enableCopying: "True" | "False"
  controlEditing: "AnyExceptExtractingPages" | "NotPermitted"
  controlPrinting: "HighResolution" | "NotPermitted"
  requireControlEditPassword: "True" | "False" — when True, add <ControlPassword><Calculation><![CDATA["password"]]></Calculation></ControlPassword>
  requireOpenPassword: "True" | "False" — when True, add <OpenPassword><Calculation><![CDATA["password"]]></Calculation></OpenPassword>
-->
<!-- View attributes:
  magnification: "25" | "50" | "75" | "100" | "125" | "150" | "200" | "400" | "800" | "FitVisible" | "FitWidth" | "FitPage" | "Default"
  pageLayout: "SinglePage" | "Default" | "Continuous" | "Facing" | "ContinuousFacing"
  show: "PagesPanelAndPage" | "PageOnly" | "BookmarksPanelAndPage"
-->
<!-- Required: UniversalPathList (output file path). -->
<!-- Optional: NoInteract, Option (Append), CreateDirectories, Restore, AutoOpen, CreateEmail, Calculation (stored label), PDFOptions (with Document, Security, View elements). -->
<!-- Document elements: Title, Subject, Author, Keywords (all calculated), Pages (AllPages; when False use NumberFrom and PageRange). -->
<!-- See https://help.claris.com/en/pro-help/content/save-records-as-pdf.html -->

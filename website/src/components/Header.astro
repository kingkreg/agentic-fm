---
const base = import.meta.env.BASE_URL;
const pathname = Astro.url.pathname.replace(base, '/');

const links = [
  { href: `${base}`, label: 'Home' },
  { href: 'https://plugin.agentic-fm.com', label: 'Plug-in', interstitial: true },
  { href: `${base}installation/`, label: 'Install' },
  { href: `${base}docs/`, label: 'Docs' },
  { href: `${base}skills/`, label: 'Skills' },
  { href: `${base}webviewer/`, label: 'Webviewer' },
  { href: `${base}philosophy/`, label: 'Philosophy' },
  { href: `${base}contributing/`, label: 'Contribute' },
];

function isActive(href: string): boolean {
  const normalized = pathname.endsWith('/') ? pathname : pathname + '/';
  const normalizedHref = href.replace(base, '/');
  if (normalizedHref === '/') return normalized === '/';
  return normalized.startsWith(normalizedHref);
}
---

<header
  class="sticky top-0 z-50 border-b border-zinc-200 bg-white/80 backdrop-blur-lg dark:border-zinc-800 dark:bg-zinc-950/80"
>
  <nav class="mx-auto flex h-16 max-w-6xl items-center justify-between px-6">
    <a href={base} class="flex items-center gap-2.5 font-semibold text-zinc-900 dark:text-white">
      <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-primary-600 text-sm font-bold text-white">
        fm
      </span>
      <span class="hidden sm:inline">agentic-fm</span>
    </a>

    <div class="hidden items-center gap-1 md:flex">
      {links.map((link) => (
        <a
          href={link.href}
          data-interstitial={link.interstitial ? 'true' : undefined}
          class:list={[
            'rounded-md px-3 py-1.5 text-sm font-medium transition-colors',
            isActive(link.href)
              ? 'bg-zinc-100 text-zinc-900 dark:bg-zinc-800 dark:text-white'
              : 'text-zinc-600 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-white',
          ]}
        >
          {link.label}
        </a>
      ))}
    </div>

    <div class="flex items-center gap-3">
      <button
        id="theme-toggle"
        class="rounded-md p-2 text-zinc-500 transition-colors hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-white"
        aria-label="Toggle dark mode"
      >
        <svg class="hidden h-5 w-5 dark:block" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
        </svg>
        <svg class="block h-5 w-5 dark:hidden" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" />
        </svg>
      </button>

      <a
        href="https://github.com/petrowsky/agentic-fm"
        target="_blank"
        rel="noopener noreferrer"
        class="hidden items-center gap-2 rounded-md bg-zinc-900 px-3.5 py-1.5 text-sm font-medium text-white transition-colors hover:bg-zinc-700 dark:bg-white dark:text-zinc-900 dark:hover:bg-zinc-200 sm:flex"
      >
        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
        </svg>
        Star on GitHub
      </a>

      <button
        id="mobile-menu-toggle"
        class="rounded-md p-2 text-zinc-500 md:hidden"
        aria-label="Toggle menu"
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </button>
    </div>
  </nav>

  <div id="mobile-menu" class="hidden border-t border-zinc-200 px-6 py-4 md:hidden dark:border-zinc-800">
    {links.map((link) => (
      <a
        href={link.href}
        data-interstitial={link.interstitial ? 'true' : undefined}
        class:list={[
          'block rounded-md px-3 py-2 text-sm font-medium',
          isActive(link.href)
            ? 'bg-zinc-100 text-zinc-900 dark:bg-zinc-800 dark:text-white'
            : 'text-zinc-600 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-white',
        ]}
      >
        {link.label}
      </a>
    ))}
    <a
      href="https://github.com/petrowsky/agentic-fm"
      target="_blank"
      rel="noopener noreferrer"
      class="mt-2 flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-zinc-600 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-white"
    >
      <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
        <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
      </svg>
      GitHub
    </a>
  </div>
</header>

<div
  id="interstitial-overlay"
  class="fixed inset-0 z-[100] hidden items-center justify-center bg-zinc-900/40 p-6 backdrop-blur-md"
  role="dialog"
  aria-modal="true"
  aria-labelledby="interstitial-title"
  data-target=""
>
    <div
      class="w-full max-w-md rounded-2xl border border-zinc-200 bg-white p-8 text-center shadow-2xl dark:border-zinc-800 dark:bg-zinc-900"
    >
      <div class="mx-auto mb-6 flex h-36 w-36 items-center justify-center gap-4 rounded-full bg-primary-600 text-white">
        <svg id="database-icon" xmlns="http://www.w3.org/2000/svg" width="47" height="47" fill="currentColor" class="bi bi-database" viewBox="0 0 16 16">
          <path d="M4.318 2.687C5.234 2.271 6.536 2 8 2s2.766.27 3.682.687C12.644 3.125 13 3.627 13 4c0 .374-.356.875-1.318 1.313C10.766 5.729 9.464 6 8 6s-2.766-.27-3.682-.687C3.356 4.875 3 4.373 3 4c0-.374.356-.875 1.318-1.313M13 5.698V7c0 .374-.356.875-1.318 1.313C10.766 8.729 9.464 9 8 9s-2.766-.27-3.682-.687C3.356 7.875 3 7.373 3 7V5.698c.271.202.58.378.904.525C4.978 6.711 6.427 7 8 7s3.022-.289 4.096-.777A5 5 0 0 0 13 5.698M14 4c0-1.007-.875-1.755-1.904-2.223C11.022 1.289 9.573 1 8 1s-3.022.289-4.096.777C2.875 2.245 2 2.993 2 4v9c0 1.007.875 1.755 1.904 2.223C4.978 15.71 6.427 16 8 16s3.022-.289 4.096-.777C13.125 14.755 14 14.007 14 13zm-1 4.698V10c0 .374-.356.875-1.318 1.313C10.766 11.729 9.464 12 8 12s-2.766-.27-3.682-.687C3.356 10.875 3 10.373 3 10V8.698c.271.202.58.378.904.525C4.978 9.71 6.427 10 8 10s3.022-.289 4.096-.777A5 5 0 0 0 13 8.698m0 3V13c0 .374-.356.875-1.318 1.313C10.766 14.729 9.464 15 8 15s-2.766-.27-3.682-.687C3.356 13.875 3 13.373 3 13v-1.302c.271.202.58.378.904.525C4.978 12.71 6.427 13 8 13s3.022-.289 4.096-.777c.324-.147.633-.323.904-.525" />
        </svg>
        <svg id="plugin-piece" xmlns="http://www.w3.org/2000/svg" width="47" height="47" fill="currentColor" viewBox="0 0 256 256">
          <path d="M220.27,158.54a8,8,0,0,0-7.7-.46,20,20,0,1,1,0-36.16A8,8,0,0,0,224,114.69V72a16,16,0,0,0-16-16H171.78a35.36,35.36,0,0,0,.22-4,36.11,36.11,0,0,0-11.36-26.24,36,36,0,0,0-60.55,23.62,36.56,36.56,0,0,0,.14,6.62H64A16,16,0,0,0,48,72v32.22a35.36,35.36,0,0,0-4-.22,36.12,36.12,0,0,0-26.24,11.36,35.7,35.7,0,0,0-9.69,27,36.08,36.08,0,0,0,33.31,33.6,35.68,35.68,0,0,0,6.62-.14V208a16,16,0,0,0,16,16H208a16,16,0,0,0,16-16V165.31A8,8,0,0,0,220.27,158.54ZM208,208H64V165.31a8,8,0,0,0-11.43-7.23,20,20,0,1,1,0-36.16A8,8,0,0,0,64,114.69V72h46.69a8,8,0,0,0,7.23-11.43,20,20,0,1,1,36.16,0A8,8,0,0,0,161.31,72H208v32.23a35.68,35.68,0,0,0-6.62-.14A36,36,0,0,0,204,176a35.36,35.36,0,0,0,4-.22Z" />
        </svg>
      </div>
      <h2 id="interstitial-title" class="text-xl font-semibold text-zinc-900 dark:text-white">
        Get ready to plug AI directly into FileMaker!
      </h2>
      <p class="mt-4 text-sm text-zinc-600 dark:text-zinc-400">
        Start automating your development in ways you never thought possible.
      </p>
      <p class="mt-4 text-sm text-zinc-600 dark:text-zinc-400">
        You're being taken to the
        <span class="font-medium text-primary-600 dark:text-primary-400">plugin.agentic-fm.com</span>
        web site.
      </p>
      <div class="mt-6 text-sm font-medium text-zinc-500 dark:text-zinc-400">
        Redirecting in <span id="interstitial-count" class="text-primary-600 dark:text-primary-400">10</span>&hellip;
      </div>
      <div class="mt-5 flex items-center justify-center gap-3">
        <button
          id="interstitial-cancel"
          class="rounded-md border border-zinc-300 px-4 py-1.5 text-sm font-medium text-zinc-500 transition-colors hover:border-zinc-400 hover:text-zinc-900 dark:border-zinc-700 dark:text-zinc-400 dark:hover:border-zinc-600 dark:hover:text-white"
        >
          Cancel
        </button>
        <button
          id="interstitial-continue"
          class="rounded-md bg-primary-600 px-4 py-1.5 text-sm font-medium text-white transition-colors hover:bg-primary-700"
        >
          Continue
        </button>
      </div>
    </div>
</div>

<style>
  /* 4s total. First 3s (0–75%): puzzle rotates 360° in place. Last 1s (75–100%):
     both icons close the gap, each moving 13.5px toward the center. The joined
     pair stays centered in the div. */
  @keyframes plugIn {
    0% { transform: rotate(0deg) translateX(0); }
    75% { transform: rotate(360deg) translateX(0); }
    100% { transform: rotate(360deg) translateX(-13.5px); }
  }

  @keyframes dockDatabase {
    0%, 75% { transform: translateX(0); }
    100% { transform: translateX(13.5px); }
  }

  #plugin-piece.is-plugging {
    animation: plugIn 4s ease-in-out forwards;
  }

  #database-icon.is-plugging {
    animation: dockDatabase 4s ease-in-out forwards;
  }
</style>

<script>
  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const html = document.documentElement;
    const isDark = html.classList.contains('dark');
    html.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'light' : 'dark');
  });

  document.getElementById('mobile-menu-toggle')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.toggle('hidden');
  });

  (() => {
    const overlay = document.getElementById('interstitial-overlay');
    const countEl = document.getElementById('interstitial-count');
    const cancelBtn = document.getElementById('interstitial-cancel');
    const continueBtn = document.getElementById('interstitial-continue');
    const piece = document.getElementById('plugin-piece');
    const database = document.getElementById('database-icon');
    if (!overlay || !countEl || !cancelBtn || !continueBtn) return;

    const DURATION = 10;
    let timer: ReturnType<typeof setInterval> | null = null;
    let target = '';

    function close() {
      if (timer) clearInterval(timer);
      timer = null;
      overlay.classList.add('hidden');
      overlay.classList.remove('flex');
      [piece, database].forEach((el) => el?.classList.remove('is-plugging'));
    }

    function start(href: string) {
      target = href;
      let remaining = DURATION;
      countEl.textContent = String(remaining);
      overlay.classList.remove('hidden');
      overlay.classList.add('flex');
      // Restart the plug-in animation each time the dialog opens.
      [piece, database].forEach((el) => {
        if (!el) return;
        el.classList.remove('is-plugging');
        void el.offsetWidth; // force reflow so the animation re-runs
        el.classList.add('is-plugging');
      });
      timer = setInterval(() => {
        remaining -= 1;
        countEl.textContent = String(Math.max(remaining, 0));
        if (remaining <= 0) {
          close();
          window.location.href = target;
        }
      }, 1000);
    }

    document.querySelectorAll<HTMLAnchorElement>('a[data-interstitial]').forEach((link) => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        start(link.href);
      });
    });

    cancelBtn.addEventListener('click', close);
    continueBtn.addEventListener('click', () => {
      close();
      window.location.href = target;
    });
    overlay.addEventListener('click', (e) => {
      if (e.target === overlay) close();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !overlay.classList.contains('hidden')) close();
    });
  })();
</script>
